---
// import ClientRouter from "astro/components/ClientRouter.astro";
import { ClientRouter } from "astro:transitions";

const {
  siteName = "Duowork Software Solutions",
  title = "Duowork Software Solutions",
  description = "We help businesses automate and scale their business vision to the top.",
  imageUrl = "https://www.duowork.tech/metaimage.jpeg",
  pageUrl = "https://www.duowork.tech",
  twitterHandle = "@duoworhq",
} = Astro.props;
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    {title ? `Duowork | ${title}` : title}
  </title>
  <link rel="icon" href="/favicon.ico" />

  <!-- PWA -->
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#9eff51" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Duowork" />
  <link rel="apple-touch-icon" href="/icon-192.png" />

  <!-- Client router for SPA-like navigation -->
  <ClientRouter />

  <!-- Google Meta Tags -->
  <meta name="description" content={description} />
  <meta
    name="keywords"
    content="custom-software-solution, abuja-website-agency, duowork-software-solutions, custom-software, tailor-made-software."
  />
  <meta name="author" content="Duowork software solutions, Romeo Peter" />
  <meta name="robots" content="index, follow" />

  <!-- Twitter Meta Tags -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content={twitterHandle} />
  <meta name="twitter:title" content={siteName} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={imageUrl} />

  <!-- Facebook Open Graph Meta Tags -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={imageUrl} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={siteName} />

  <!-- Astro default-->
  <meta name="generator" content={Astro.generator} />

  <!-- Service Worker Registration -->
  <script>
    if ("serviceWorker" in navigator) {
      window.addEventListener("load", () => {
        navigator.serviceWorker
          .register("/sw.js")
          .then((reg) => console.log("[SW] Registered:", reg.scope))
          .catch((err) => console.warn("[SW] Registration failed:", err));
      });
    }
  </script>
</head>
